{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/src/tauri.conf.json",
  "productName": "NoteHub",
  "version": "0.1.0",
  "identifier": "com.notehub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "NoteHub",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/stargately/notehub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDNjFERTM2QURGRkE2MjIKUldRaXB2K3ROdDVoL0cvZkdFT0g0TGR6QVY2dTRSZ2k5N1AyeWZuREZjR2tOQlJQVENCL3dsSHEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "mdx"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      }
    ]
  }
}
